upstream docflow_backend {
    server 127.0.0.1:8080;
    keepalive 16;
}

server {
    listen 80;
    server_name docflow.example.com;
    # 强制 HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name docflow.example.com;

    # 证书路径 (Let's Encrypt 或自签均可)
    ssl_certificate     /etc/ssl/docflow/fullchain.pem;
    ssl_certificate_key /etc/ssl/docflow/privkey.pem;

    # 允许上传略大于业务上限的请求体,与 Gin MaxBytesReader 协同
    client_max_body_size 21m;

    # 前端静态资源
    root /var/www/docflow;
    index index.html;

    # API 反代到 Go 服务
    location /api/ {
        proxy_pass http://docflow_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
        # 上传/下载大文件需放宽缓冲
        proxy_request_buffering off;
        proxy_buffering off;
    }

    # 健康检查
    location = /healthz {
        proxy_pass http://docflow_backend;
    }

    # Vue history 模式 fallback
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 静态资源缓存
    location ~* \.(?:js|css|woff2?|ttf|svg|png|jpg|jpeg|gif|webp)$ {
        expires 30d;
        access_log off;
        add_header Cache-Control "public, immutable";
    }

    access_log /var/log/nginx/docflow_access.log;
    error_log  /var/log/nginx/docflow_error.log;
}
